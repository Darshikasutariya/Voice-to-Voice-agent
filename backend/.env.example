# Ingestion and crawling
CRAWL_BASE_URL=https://taxone.vyapar.com/help
CRAWL_MAX_DEPTH=3
CRAWL_DELAY_MS=500
CRAWL_CONCURRENCY=4

# Chroma
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=taxone_help_v1

# OpenAI (required for POST /api/chat)
OPENAI_API_KEY=
# Optional — default gpt-4o-mini
OPENAI_MODEL=

# HTTP + WebSocket (/ws/chat on same port)
HOST=0.0.0.0
PORT=3001
# Comma-separated origins, or * / unset for reflect-any-origin (dev)
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# --- Hardening (optional) ---
# If set, required for POST /api/chat (X-API-Key or Authorization: Bearer)
# and WebSocket (?apiKey= on URL or "apiKey" in JSON).
CHAT_API_KEY=

# HTTP: max chat requests per IP per window (default 60s / 30)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# WebSocket: max incoming JSON messages (questions) per IP per window
WS_RATE_LIMIT_WINDOW_MS=60000
WS_RATE_LIMIT_MAX=20

# Set to 1 when behind nginx/caddy so rate limit uses X-Forwarded-For
TRUST_PROXY=

# --- Voice (customer support / hold-to-speak) ---
# STT: deepgram | sarvam (default deepgram; TTS is always Sarvam on /api/voice/tts)
VOICE_STT_PROVIDER=deepgram
# Deepgram (paid API key)
DEEPGRAM_API_KEY=
# Optional — see Deepgram model docs (default nova-2)
# DEEPGRAM_MODEL=nova-2
# DEEPGRAM_LANGUAGE=en-IN

# Sarvam (paid API key — used for TTS; optional for STT when VOICE_STT_PROVIDER=sarvam)
SARVAM_API_KEY=
# SARVAM_STT_MODEL=saaras:v3
# SARVAM_STT_LANGUAGE=unknown
# SARVAM_TTS_MODEL=bulbul:v3
# SARVAM_TTS_SPEAKER=shubh
# SARVAM_TTS_LANG=en-IN

# Per-minute cap on /api/voice/transcribe + /api/voice/tts (default 45)
# VOICE_RATE_LIMIT_MAX=45
