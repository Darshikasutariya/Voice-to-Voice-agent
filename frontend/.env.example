# Backend URL (HTTP). WebSocket uses ws/wss on the same host.
VITE_BACKEND_URL=http://localhost:3001

# Optional — same value as backend CHAT_API_KEY if you enabled it
# VITE_CHAT_API_KEY=

# If true, use browser speechSynthesis for replies instead of Sarvam TTS (dev only)
# VITE_VOICE_BROWSER_TTS_FALLBACK=false
